# 🛡️ WAF Configuration - Customize for Your Website

# ===== TARGET WEBSITE =====
# Change these to point to your actual website
TARGET_WEBSITE_HOST=juice-shop    # Internal service name (change if using external URL)
TARGET_WEBSITE_PORT=3000          # Port of your application
TARGET_WEBSITE_URL=http://juice-shop:3000  # Full URL (internal: service:port, external: domain.com)

# ===== PUBLIC ENDPOINT =====
# This is the public-facing URL where users access your website
PUBLIC_IP_OR_DOMAIN=localhost     # Change to your domain (e.g., mysite.com, 192.168.1.100)
PUBLIC_PORT=8080                  # Internet-facing port

# ===== WAF CONFIGURATION =====
# AI Detection Sensitivity (0.5 = aggressive, 0.95 = conservative)
AI_CONFIDENCE_THRESHOLD=0.95

# Uncertainty threshold (flags borderline predictions)
UNCERTAINTY_THRESHOLD=0.85

# ===== LOGGING =====
# Enable detailed logging (true/false)
ENABLE_DETAILED_LOGGING=true

# ===== MODEL SETTINGS =====
# Path to model weights (relative to project root)
MODEL_PATH=/app/model/weights

# ===== MONITORING =====
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=10

# Monitoring daemon check interval (seconds)  
MONITOR_CHECK_INTERVAL=30

# Email for alerts (optional - leave empty to disable)
ALERT_EMAIL=

# ===== RESOURCE LIMITS =====
# WAF service CPU/Memory limits
WAF_CPU_LIMIT=1.0
WAF_CPU_RESERVE=0.5
WAF_MEMORY_LIMIT=1024M
WAF_MEMORY_RESERVE=512M

# ===== LOG ROTATION =====
# Max log file size before rotation
LOG_MAX_SIZE=50m

# Max number of log files to keep
LOG_MAX_FILES=10
